---
interface Props {
  name: string;
  description: string;
  category: string;
  tags: string[];
  author: string;
  icon: string;
  featured?: boolean;
}

const { name, description, category, tags, author, icon, featured = false } = Astro.props;
---

<article
  class:list={['plugin-card', { 'plugin-card--featured': featured }]}
  data-name={name}
  data-description={description}
  data-category={category}
  data-tags={tags.join(',')}
  data-author={author}
  tabindex="0"
  role="button"
>
  <div class="plugin-card-top">
    <span class="plugin-card-icon">{icon}</span>
    {featured && <span class="plugin-card-featured">Featured</span>}
  </div>

  <h3 class="plugin-card-name">{name}</h3>
  <p class="plugin-card-description">{description}</p>

  <div class="plugin-card-meta">
    <span class="plugin-card-category">{category}</span>
    <div class="plugin-card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="plugin-card-tag">{tag}</span>
      ))}
    </div>
  </div>

  <div class="plugin-card-footer">
    <span class="plugin-card-author">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      {author}
    </span>
  </div>
</article>

<style>
  .plugin-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition:
      transform var(--transition-normal),
      border-color var(--transition-normal),
      box-shadow var(--transition-normal),
      background var(--transition-normal);
    overflow: hidden;
  }

  .plugin-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-brand-gradient);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .plugin-card:hover,
  .plugin-card:focus-visible {
    transform: translateY(-3px);
    border-color: var(--color-border-hover);
    background: var(--color-bg-card-hover);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
  }

  .plugin-card:hover::before,
  .plugin-card:focus-visible::before {
    opacity: 1;
  }

  .plugin-card:focus-visible {
    outline: 2px solid var(--color-primary-light);
    outline-offset: 2px;
  }

  .plugin-card--featured {
    border-color: rgba(0, 165, 184, 0.2);
  }

  .plugin-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .plugin-card-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .plugin-card-featured {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary-light);
    background: rgba(0, 165, 184, 0.12);
    padding: 3px 8px;
    border-radius: var(--radius-full);
  }

  .plugin-card-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .plugin-card-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin-bottom: 16px;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .plugin-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .plugin-card-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-blue);
    background: rgba(126, 200, 227, 0.1);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
  }

  .plugin-card-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .plugin-card-tag {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-bg-surface);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  .plugin-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid var(--color-border);
  }

  .plugin-card-author {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .plugin-card {
      padding: 18px;
    }
  }
</style>
