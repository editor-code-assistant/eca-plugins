---
import { REPO_URL } from '../constants';

interface Props {
  pluginCount: number;
}

const { pluginCount } = Astro.props;
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-glow hero-glow--1"></div>
    <div class="hero-glow hero-glow--2"></div>
    <div class="hero-glow hero-glow--3"></div>
    <div class="hero-orb hero-orb--1"></div>
    <div class="hero-orb hero-orb--2"></div>
    <div class="hero-orb hero-orb--3"></div>
    <div class="hero-grid"></div>
    <div class="hero-noise"></div>
  </div>
  <div class="hero-content container">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      {pluginCount} plugins available
    </div>
    <h1 class="hero-title">
      Extend ECA with
      <span class="hero-highlight">community plugins</span>
    </h1>
    <p class="hero-subtitle">
      Browse, discover, and install plugins that add skills, agents, rules, and more to your editor AI assistant.
    </p>
    <div class="hero-search">
      <svg class="hero-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <!-- Coupled: PluginGrid.astro reads #search-input for filtering -->
      <input
        type="text"
        id="search-input"
        class="hero-search-input"
        placeholder="Search plugins..."
        autocomplete="off"
        autofocus
      />
      <kbd class="hero-search-kbd">/</kbd>
    </div>
    <p class="hero-contribute">
      Have a plugin idea?
      <a href={`${REPO_URL}/blob/master/CONTRIBUTING.md`} class="hero-contribute-link" target="_blank" rel="noopener">
        Share it with the community
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </p>
  </div>
  <div class="hero-fade"></div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 80px 0 56px;
  }

  /* Layered background like eca.dev hero */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0, 165, 184, 0.18) 0%, transparent 100%),
      radial-gradient(ellipse 60% 80% at 20% 20%, rgba(0, 82, 104, 0.25) 0%, transparent 70%),
      radial-gradient(ellipse 50% 70% at 80% 10%, rgba(0, 122, 148, 0.2) 0%, transparent 70%),
      linear-gradient(180deg,
        #00a5b8 0%,
        #007a94 15%,
        #005268 40%,
        var(--color-bg-primary) 100%
      );
    opacity: 0.5;
  }

  /* Large ambient glows — slow drifting animation */
  .hero-glow--1 {
    position: absolute;
    top: -30%;
    left: 20%;
    width: 60%;
    height: 90%;
    background: radial-gradient(ellipse at center, rgba(0, 165, 184, 0.22) 0%, transparent 65%);
    animation: glowDrift1 12s ease-in-out infinite;
  }

  .hero-glow--2 {
    position: absolute;
    top: -15%;
    right: 5%;
    width: 45%;
    height: 70%;
    background: radial-gradient(ellipse at center, rgba(0, 122, 148, 0.18) 0%, transparent 65%);
    animation: glowDrift2 15s ease-in-out infinite;
  }

  .hero-glow--3 {
    position: absolute;
    bottom: -10%;
    left: 5%;
    width: 40%;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(0, 165, 184, 0.1) 0%, transparent 65%);
    animation: glowDrift3 18s ease-in-out infinite;
  }

  /* Floating orbs — animated blurred circles */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    will-change: transform;
  }

  .hero-orb--1 {
    top: 5%;
    left: 15%;
    width: 200px;
    height: 200px;
    background: rgba(0, 165, 184, 0.15);
    animation: orbFloat1 20s ease-in-out infinite;
  }

  .hero-orb--2 {
    top: 20%;
    right: 20%;
    width: 150px;
    height: 150px;
    background: rgba(0, 122, 148, 0.12);
    animation: orbFloat2 25s ease-in-out infinite;
  }

  .hero-orb--3 {
    bottom: 15%;
    left: 50%;
    width: 180px;
    height: 180px;
    background: rgba(0, 165, 184, 0.08);
    animation: orbFloat3 22s ease-in-out infinite;
  }

  /* Dot grid with cross-fade lines for a mesh look */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 165, 184, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 165, 184, 0.04) 1px, transparent 1px),
      radial-gradient(rgba(0, 165, 184, 0.06) 1px, transparent 1px);
    background-size: 64px 64px, 64px 64px, 32px 32px;
    mask-image: radial-gradient(ellipse 70% 55% at 50% 25%, black 10%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 55% at 50% 25%, black 10%, transparent 75%);
  }

  /* Film grain / noise texture for depth */
  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    mix-blend-mode: overlay;
  }

  @keyframes glowDrift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(3%, 5%) scale(1.05); }
    66% { transform: translate(-2%, -3%) scale(0.97); }
  }

  @keyframes glowDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-4%, 3%) scale(1.03); }
    66% { transform: translate(2%, -4%) scale(0.98); }
  }

  @keyframes glowDrift3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(5%, -3%) scale(1.06); }
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(40px, -20px); }
    50% { transform: translate(-10px, 30px); }
    75% { transform: translate(25px, 10px); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(-30px, 15px); }
    50% { transform: translate(20px, -25px); }
    75% { transform: translate(-15px, -10px); }
  }

  @keyframes orbFloat3 {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(25px, -35px); }
    66% { transform: translate(-30px, 15px); }
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--color-bg-primary));
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    max-width: 720px;
    animation: fadeIn 0.6s ease;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary-light);
    background: rgba(0, 165, 184, 0.08);
    border: 1px solid rgba(0, 165, 184, 0.2);
    padding: 6px 16px;
    border-radius: var(--radius-full);
    margin-bottom: 28px;
    backdrop-filter: blur(8px);
  }

  .hero-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-green);
    box-shadow: 0 0 8px var(--color-accent-green);
    animation: pulseGlow 3s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 18px;
    color: #fff;
  }

  .hero-highlight {
    background: linear-gradient(90deg, #00a5b8, #4dc9da, #00c8de, #00a5b8);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: highlightShimmer 6s ease-in-out infinite;
  }

  @keyframes highlightShimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 540px;
    margin: 0 auto 36px;
    line-height: 1.65;
  }

  .hero-search {
    position: relative;
    max-width: 500px;
    margin: 0 auto;
  }

  .hero-search-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 15px 52px 15px 50px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text-primary);
    background: rgba(19, 26, 34, 0.8);
    border: 1px solid rgba(30, 42, 52, 0.8);
    border-radius: var(--radius-lg);
    outline: none;
    backdrop-filter: blur(8px);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  }

  .hero-search-input::placeholder {
    color: var(--color-text-muted);
  }

  .hero-search-input:focus {
    border-color: var(--color-primary-light);
    box-shadow: 0 0 0 3px rgba(0, 165, 184, 0.15), var(--shadow-glow);
    background: rgba(19, 26, 34, 0.95);
  }

  .hero-search-kbd {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: rgba(30, 42, 52, 0.6);
    border: 1px solid rgba(30, 42, 52, 0.8);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    pointer-events: none;
    line-height: 1.3;
  }

  .hero-contribute {
    margin-top: 20px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .hero-contribute-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-accent-green, #34d399);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .hero-contribute-link:hover {
    color: #6ee7b7;
  }

  .hero-contribute-link svg {
    transition: transform var(--transition-fast);
  }

  .hero-contribute-link:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 48px 0 32px;
    }

    .hero-title {
      font-size: 1.8rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
      margin-bottom: 28px;
    }

    .hero-search-input {
      padding: 13px 18px 13px 46px;
      font-size: 0.95rem;
    }

    .hero-search-icon {
      left: 16px;
    }

    /* Kbd hint is useless on touch devices */
    .hero-search-kbd {
      display: none;
    }

    .hero-badge {
      margin-bottom: 20px;
    }

    .hero-contribute {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 640px) {
    .hero-orb { display: none; }
    .hero-noise { display: none; }
  }

  @media (max-width: 380px) {
    .hero {
      padding: 40px 0 28px;
    }

    .hero-title {
      font-size: 1.55rem;
    }

    .hero-subtitle {
      font-size: 0.88rem;
      margin-bottom: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow--1,
    .hero-glow--2,
    .hero-glow--3,
    .hero-orb--1,
    .hero-orb--2,
    .hero-orb--3,
    .hero-highlight {
      animation: none;
    }
  }
</style>
