<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(14, 14, 26, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-height);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text-primary);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .header-brand:hover {
    color: var(--color-text-primary);
  }

  .header-logo {
    color: var(--color-primary-light);
    flex-shrink: 0;
  }

  .header-title {
    white-space: nowrap;
  }

  .header-badge {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    background: var(--color-brand-gradient);
    color: white;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .header-link:hover {
    color: var(--color-text-primary);
  }

  .header-link--eca {
    color: var(--color-primary-light);
    font-weight: 500;
  }

  .header-link--eca:hover {
    color: #4dc9da;
  }

  @media (max-width: 640px) {
    .header-nav {
      gap: 14px;
    }

    .header-link span,
    .header-badge {
      display: none;
    }
  }
</style>
