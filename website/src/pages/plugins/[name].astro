---
import fs from 'node:fs';
import path from 'node:path';

import type { Plugin } from '../../types/plugin';
import { plugins } from '../../data/marketplace';
import { pluginSourceUrl } from '../../constants';
import { renderMarkdown } from '../../utils/markdown';
import Layout from '../../layouts/Layout.astro';
import GitHubAvatar from '../../components/GitHubAvatar.astro';

export function getStaticPaths() {
  return plugins.map((plugin) => ({
    params: { name: plugin.name },
    props: { plugin },
  }));
}

const { plugin } = Astro.props as { plugin: Plugin };

let readmeHtml = '';
const readmePath = path.resolve('..', plugin.source, 'README.md');
if (fs.existsSync(readmePath)) {
  const md = fs.readFileSync(readmePath, 'utf-8');
  readmeHtml = await renderMarkdown(md);
}

const installCommand = `/plugin-install ${plugin.name}`;
const configSnippet = `{
  "plugins": {
    "install": ["${plugin.name}"]
  }
}`;
---

<Layout title={`${plugin.name} — ECA Plugin`} description={plugin.description}>
  <main class="detail-main">
    <div class="container">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to plugins
      </a>

      <div class="detail-layout">
        <div class="detail-content">
          <div class="detail-header">
            <span class="detail-icon">{plugin.icon}</span>
            <div>
              <h1 class="detail-name">{plugin.name}</h1>
              <p class="detail-description">{plugin.description}</p>
            </div>
          </div>

          <div class="detail-meta">
            <span class="detail-category">{plugin.category}</span>
            <div class="detail-tags">
              {plugin.tags.map(tag => (
                <span class="detail-tag">{tag}</span>
              ))}
            </div>
          </div>

          <div class="detail-author">
            <GitHubAvatar author={plugin.author} size={40} class="detail-author-avatar" />
            <a href={`https://github.com/${plugin.author}`} target="_blank" rel="noopener">{plugin.author}</a>
          </div>

          {readmeHtml && (
            <div class="detail-readme">
              <div class="detail-readme-divider"></div>
              <div class="detail-readme-content" set:html={readmeHtml} />
            </div>
          )}
        </div>

        <aside class="detail-sidebar">
          <div class="detail-install">
            <h3 class="detail-install-title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Install
            </h3>

            <p class="detail-install-hint">Run this command in the ECA chat:</p>
            <div class="detail-command">
              <pre class="detail-command-code" id="command-code">{installCommand}</pre>
              <button class="detail-copy-btn" aria-label="Copy command to clipboard" data-copy="command">
                <svg class="detail-copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <svg class="detail-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden>
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </button>
            </div>

            <details class="detail-manual">
              <summary class="detail-manual-toggle">
                <svg class="detail-manual-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
                Manual config.json setup
              </summary>
              <div class="detail-manual-content">
                <p class="detail-install-hint">Add to your <code>config.json</code> (global or project-level):</p>
                <div class="detail-config">
                  <pre class="detail-code" id="config-code">{configSnippet}</pre>
                  <button class="detail-copy-btn detail-copy-btn--sm" aria-label="Copy config to clipboard" data-copy="config">
                    <svg class="detail-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    <svg class="detail-check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden>
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </button>
                </div>
              </div>
            </details>
          </div>

          <div class="detail-info">
            <div class="detail-info-row">
              <span class="detail-info-label">Category</span>
              <span class="detail-info-value">{plugin.category}</span>
            </div>
            <div class="detail-info-row">
              <span class="detail-info-label">Author</span>
              <span class="detail-info-value">
                <GitHubAvatar author={plugin.author} size={32} class="detail-info-avatar" />
                {plugin.author}
              </span>
            </div>
            <div class="detail-info-row">
              <span class="detail-info-label">Source</span>
              <a href={pluginSourceUrl(plugin.source)} target="_blank" rel="noopener" class="detail-info-link">
                View on GitHub →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</Layout>

<script>
  const sources: Record<string, string> = {
    command: document.getElementById('command-code')?.textContent ?? '',
    config: document.getElementById('config-code')?.textContent ?? '',
  };

  document.querySelectorAll<HTMLButtonElement>('.detail-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.copy ?? '';
      const text = sources[key] ?? '';
      const copyIcon = btn.querySelector<SVGElement>('.detail-copy-icon')!;
      const checkIcon = btn.querySelector<SVGElement>('.detail-check-icon')!;

      try {
        await navigator.clipboard.writeText(text);
        copyIcon.setAttribute('hidden', '');
        checkIcon.removeAttribute('hidden');

        setTimeout(() => {
          copyIcon.removeAttribute('hidden');
          checkIcon.setAttribute('hidden', '');
        }, 2000);
      } catch {
        /* Fallback: select the text */
        const codeEl = document.getElementById(key === 'command' ? 'command-code' : 'config-code');
        if (codeEl) {
          const range = document.createRange();
          range.selectNodeContents(codeEl);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    });
  });
</script>

<style>
  .detail-main {
    min-height: calc(100vh - var(--header-height) - 100px);
    padding: 32px 0 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-primary-light);
  }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 40px;
    align-items: start;
    max-width: 1320px;
    margin: 0 auto;
  }

  .detail-header {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .detail-icon {
    font-size: 3rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .detail-name {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .detail-description {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .detail-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-blue);
    background: rgba(126, 200, 227, 0.1);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }

  .detail-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .detail-tag {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-surface);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .detail-author {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 24px;
  }



  .detail-author a {
    color: var(--color-text-secondary);
  }

  .detail-author a:hover {
    color: var(--color-primary-light);
  }

  /* README */
  .detail-readme {
    margin-top: 8px;
  }

  .detail-readme-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 24px;
  }

  .detail-readme-content {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .detail-readme-content :global(h1) {
    display: none;
  }

  .detail-readme-content :global(h2) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 28px 0 12px;
  }

  .detail-readme-content :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 20px 0 8px;
  }

  .detail-readme-content :global(p) {
    margin: 0 0 14px;
  }

  .detail-readme-content :global(ul),
  .detail-readme-content :global(ol) {
    margin: 0 0 14px;
    padding-left: 24px;
  }

  .detail-readme-content :global(li) {
    margin-bottom: 6px;
  }

  .detail-readme-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-surface);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--color-accent-blue);
  }

  .detail-readme-content :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 16px;
    overflow-x: auto;
    margin: 0 0 14px;
    line-height: 1.5;
  }

  .detail-readme-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .detail-readme-content :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .detail-readme-content :global(a) {
    color: var(--color-primary-light);
  }

  .detail-readme-content :global(a:hover) {
    color: var(--color-primary-hover);
  }

  .detail-readme-content :global(blockquote) {
    border-left: 3px solid var(--color-border-active);
    margin: 0 0 14px;
    padding: 10px 16px;
    color: var(--color-text-muted);
    background: rgba(0, 165, 184, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .detail-readme-content :global(blockquote p) {
    margin: 0;
  }

  /* Sidebar */
  .detail-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 24px);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .detail-install {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px;
    border-top: 2px solid var(--color-primary);
  }

  .detail-install-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 14px;
  }

  .detail-install-title svg {
    color: var(--color-primary-light);
    flex-shrink: 0;
  }

  .detail-install-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }

  /* Primary command block */
  .detail-command {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary-light);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    margin-bottom: 16px;
  }

  .detail-command-code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary-hover);
    white-space: nowrap;
    overflow-x: auto;
    line-height: 1.4;
    margin: 0;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .detail-command-code::-webkit-scrollbar {
    height: 4px;
  }

  .detail-command-code::-webkit-scrollbar-track {
    background: transparent;
  }

  .detail-command-code::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: var(--radius-full);
  }

  .detail-copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-text-muted);
    background: none;
    border: none;
    padding: 4px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .detail-copy-btn:hover {
    color: var(--color-primary-light);
    background: rgba(0, 165, 184, 0.1);
  }

  .detail-copy-btn--sm {
    padding: 3px;
  }

  /* Collapsible manual section */
  .detail-manual {
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
  }

  .detail-manual-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color var(--transition-fast);
  }

  .detail-manual-toggle::-webkit-details-marker {
    display: none;
  }

  .detail-manual-toggle::marker {
    content: '';
  }

  .detail-manual-toggle:hover {
    color: var(--color-text-secondary);
  }

  .detail-manual-chevron {
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .detail-manual[open] .detail-manual-chevron {
    transform: rotate(90deg);
  }

  .detail-manual-content {
    padding-top: 12px;
  }

  .detail-manual-content .detail-install-hint {
    font-size: 0.75rem;
  }

  .detail-config {
    position: relative;
  }

  .detail-config .detail-copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
  }

  .detail-code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent-blue);
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 14px;
    overflow-x: auto;
    white-space: pre;
    line-height: 1.5;
    margin: 0;
  }

  .detail-info {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .detail-info-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .detail-info-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .detail-info-value {
    font-size: 0.85rem;
    color: var(--color-text-primary);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 6px;
  }



  .detail-info-link {
    font-size: 0.8rem;
    color: var(--color-primary-light);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }

    .detail-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .detail-main {
      padding: 20px 0 48px;
    }

    .detail-header {
      flex-direction: column;
      gap: 12px;
    }

    .detail-name {
      font-size: 1.4rem;
    }

    .detail-description {
      font-size: 0.9rem;
    }

    .detail-install {
      padding: 16px;
    }

    .detail-command-code {
      font-size: 0.8rem;
    }

    .detail-info {
      padding: 16px;
    }

    .detail-code {
      font-size: 0.72rem;
      padding: 12px;
    }

    .detail-readme-content :global(pre) {
      padding: 12px;
      font-size: 0.78rem;
    }

    .detail-readme-content :global(ul),
    .detail-readme-content :global(ol) {
      padding-left: 18px;
    }
  }

  @media (max-width: 380px) {
    .detail-name {
      font-size: 1.25rem;
    }

    .detail-icon {
      font-size: 2.5rem;
    }

    .back-link {
      margin-bottom: 24px;
    }
  }
</style>
